	*
	* @returns An iterator for the processed elements. 处理后元素的迭代器
	*
	* @example
	* ```ts
	* const iterator = new ArrayIterator([1, 2, 3])
	* for (const value of iterator) {
	*   console.log(value)
	* }
	* ```
	*/
	[Symbol.iterator]() {
		return this.iterate();
	}
