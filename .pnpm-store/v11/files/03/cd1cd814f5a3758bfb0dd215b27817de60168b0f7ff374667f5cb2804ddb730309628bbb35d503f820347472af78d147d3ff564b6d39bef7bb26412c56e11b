					case OPERATION_TAKE: break;
					case OPERATION_DROP:
						if (droppedCount < dropCount) shouldDrop = true;
						break;
				}
			}
			processedCount++;
			if (shouldDrop && droppedCount < dropCount) {
				droppedCount++;
				continue;
			}
			if (shouldYield) {
				yieldedCount++;
				yield current;
			}
