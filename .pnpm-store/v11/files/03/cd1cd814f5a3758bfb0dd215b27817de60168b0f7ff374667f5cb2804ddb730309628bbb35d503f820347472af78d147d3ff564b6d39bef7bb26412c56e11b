* gcd(17, 13) // => 1
* gcd(0, 5) // => 5
* ```
*/
function gcd(a, b) {
	if (!isFinite(a) || !isFinite(b)) return NaN;
	a = Math.abs(Math.floor(a));
	b = Math.abs(Math.floor(b));
	if (a === 0) return b;
	if (b === 0) return a;
	while (b !== 0) [a, b] = [b, a % b];
	return a;
