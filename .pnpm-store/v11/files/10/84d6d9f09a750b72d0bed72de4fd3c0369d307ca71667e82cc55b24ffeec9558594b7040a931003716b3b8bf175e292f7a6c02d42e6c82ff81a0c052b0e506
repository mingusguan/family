import { a as kebabCase, i as isExclude } from "./utils-d-0sRhq1.mjs";

//#region src/resolvers/ano-ui.ts
function AnoResolver() {
	return {
		type: "component",
		resolve: (name) => {
			if (name.match(/^A[A-Z]/)) return {
				name,
				from: `ano-ui/components/${name}/${name}.vue`
			};
		}
	};
}

//#endregion
//#region src/resolvers/tdesign-uniapp.ts
function isChat(name) {
	return name === "TAttachments" || name.startsWith("TChat");
}
function TDesignUniappResolver(options = {}) {
	return {
		type: "component",
		resolve: (name) => {
			if (isExclude(name, options.exclude)) return;
			if (name.match(/^T[A-Z]/)) {
				const pureName = name.slice(1);
				const partialName = pureName === "QRCode" ? "qrcode" : kebabCase(pureName);
				return {
					name,
					from: `@tdesign/${isChat(name) ? "uniapp-chat" : "uniapp"}/${partialName}/${partialName}.vue`,
					sideEffects: "@tdesign/uniapp/common/style/theme/index.less"
				};
			}
		}
	};
}

//#endregion
//#region src/resolvers/uni-ui.ts
function UniUIResolver(options = {}) {
	return {
		type: "component",
		resolve: (name) => {
			if (isExclude(name, options.exclude) || name === "UniLayout") return;
			if (name.match(/^Uni[A-Z]/)) {
				const partialName = kebabCase(name);
				return {
					name,
					from: `@dcloudio/uni-ui/lib/${partialName}/${partialName}.vue`
				};
			}
		}
	};
}

