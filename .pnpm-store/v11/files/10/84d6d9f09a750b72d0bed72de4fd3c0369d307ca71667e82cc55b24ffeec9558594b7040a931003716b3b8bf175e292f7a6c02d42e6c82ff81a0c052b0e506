//#region src/resolvers/z-paging.ts
function ZPagingResolver(options = {}) {
	return {
		type: "component",
		resolve: (name) => {
			if (isExclude(name, options.exclude)) return;
			if (name.match(/^(?!ZPagingRefresh|ZPagingLoadMore)ZPaging(.*)/)) {
				const compName = kebabCase(name);
				return {
					name,
					from: `z-paging/components/${compName}/${compName}.vue`
				};
			}
		}
	};
}

