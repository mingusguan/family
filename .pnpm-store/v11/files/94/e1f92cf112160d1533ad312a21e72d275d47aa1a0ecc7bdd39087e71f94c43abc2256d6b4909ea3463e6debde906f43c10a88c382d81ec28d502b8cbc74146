  *
  * @example
  * ```ts
  * {
  *   A: ['B', 'C'],
  *   A: { rules: ['B', 'C'], when: ['/api/a/b/c'] }
  * }
  * ```
  */
  [key: string]: string[] | {
    rules: string[];
    when: string[];
  };
}
