# 文件存储类型，默认使用腾讯云 COS
OSS_TYPE=cos

# 腾讯云 COS 地域简称，例如 ap-guangzhou、ap-shanghai
TENCENT_COS_REGION=ap-guangzhou

# 完整存储桶名称，必须包含 APPID
TENCENT_COS_BUCKET_NAME=examplebucket-1250000000

# 腾讯云 API 密钥
TENCENT_COS_SECRET_ID=replace-with-your-secret-id
TENCENT_COS_SECRET_KEY=replace-with-your-secret-key

# 可选：自定义 CDN 或 COS 域名，留空则使用 COS 默认域名
TENCENT_COS_CUSTOM_DOMAIN=

# ????? AppID
WX_MINIAPP_APPID=replace-with-your-miniapp-appid

# ????? AppSecret???????????
WX_MINIAPP_SECRET=replace-with-your-miniapp-secret

# 生产数据库连接
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/youlai_admin?zeroDateTimeBehavior=convertToNull&useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&autoReconnect=true&allowMultiQueries=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace-with-your-database-password

# 生产 Redis 连接
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_DATABASE=1
SPRING_DATA_REDIS_PASSWORD=replace-with-your-redis-password